{
  "name": "koishi-plugin-chatluna-hub",
  "description": "IsAHub?",
  "version": "0.0.1",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs",
      "default": "./lib/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "lib",
    "dist",
    "client"
  ],
  "license": "MIT",
  "scripts": {
    "build:server": "node scripts/build-server.cjs",
    "build:client": "../../node_modules/.bin/koishi-console build",
    "build": "yarn build:server && yarn build:client"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "2.7.7",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@koishijs/client": "^5.30.11",
    "@koishijs/plugin-console": "^5.30.11",
    "koishi": "^4.18.9",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.30.11",
    "koishi": "^4.18.9"
  },
  "koishi": {
    "description": {
      "zh": "ChatLuna 生态统一 WebUI Hub",
      "en": "Unified WebUI hub for the ChatLuna ecosystem"
    },
    "service": {
      "optional": [
        "console"
      ]
    },
    "browser": true
  }
}

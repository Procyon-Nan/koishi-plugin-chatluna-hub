{
  "name": "koishi-plugin-chatluna-hub",
  "description": "Do you like long, cluttered sidebars? I don't, so here's my solution.",
  "version": "0.2.1",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "lib",
    "dist",
    "client"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Procyon-Nan/koishi-plugin-chatluna-hub.git"
  },
  "contributors": [
    "Procyon-Nan <3189960265@qq.com>"
  ],
  "scripts": {
    "build:server": "node scripts/build-server.cjs",
    "build:client": "../../node_modules/.bin/koishi-console build",
    "build": "yarn build:server && yarn build:client",
    "lint": "yarn eslint src --ext=ts",
    "lint-fix": "yarn eslint src --ext=ts --fix"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "2.7.7",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@koishijs/client": "^5.30.11",
    "@koishijs/plugin-console": "^5.30.11",
    "@typescript-eslint/eslint-plugin": "^7.18.1-alpha.3",
    "@typescript-eslint/parser": "^8.45.1-alpha.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "koishi": "^4.18.9",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.30.11",
    "koishi": "^4.18.9"
  },
  "koishi": {
    "description": {
      "zh": "ChatLuna 生态统一 WebUI Hub",
      "en": "Unified WebUI hub for the ChatLuna ecosystem"
    },
    "service": {
      "optional": [
        "console",
        "chatluna"
      ]
    },
    "browser": true
  }
}
